# Server
PORT=3001
FRONTEND_ORIGIN=http://localhost:3000

# Mail destination
CONTACT_TO=info@angelorenovates.be

# Microsoft Graph settings (preferred for Microsoft 365)
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SENDER=info@angelorenovates.be
GRAPH_API_BASE_URL=https://graph.microsoft.com/v1.0

# SMTP settings (fallback for non-Microsoft providers)
# Defaults are Outlook/Hotmail-compatible.
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Optional explicit From header (defaults to SMTP_USER)
SMTP_FROM=

# Google Places reviews (for live Google reviews on the website)
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
GOOGLE_PLACES_LANGUAGE_CODE=nl
GOOGLE_PLACES_REGION_CODE=BE
GOOGLE_REVIEWS_LIMIT=3
